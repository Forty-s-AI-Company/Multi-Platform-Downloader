{
  "name": "ai-yt-dlp",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "description": "??? yt-dlp GUI ???????????????????????? cookies ???",
  "author": "eden",
  "scripts": {
    "dev": "concurrently -n renderer,electron:build,electron:run -c cyan,magenta,yellow \"npm:dev:renderer\" \"npm:dev:electron:build\" \"npm:dev:electron:run\"",
    "dev:renderer": "vite",
    "dev:electron:build": "tsc -p electron/tsconfig.json --watch --preserveWatchOutput",
    "dev:electron:run": "wait-on http://127.0.0.1:5173 dist-electron/electron/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron dist-electron/electron/main.js",
    "start": "npm run build && electron dist-electron/electron/main.js",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p electron/tsconfig.json && node scripts/copy-electron-assets.mjs",
    "pack": "npm run build && electron-builder --dir",
    "dist:win": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\dist-win.ps1",
    "dist:mac": "npm run build && electron-builder --mac dmg --publish never",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/node": "^22.10.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^24.13.3",
    "eslint": "^9.20.1",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.23.0",
    "vite": "^6.1.1",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.2"
  }
}
